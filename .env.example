# =============================================================================
# Sequifi Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
#   php artisan key:generate
# =============================================================================

# -----------------------------------------------------------------------------
# APPLICATION SETTINGS
# -----------------------------------------------------------------------------
APP_NAME=Sequifi
APP_ENV=local                    # local, staging, production
APP_DEBUG=true                   # false in production
APP_KEY=                         # Generated by: php artisan key:generate
APP_ID=                          # Unique app identifier (UUID)
APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# DOMAIN CONFIGURATION
# -----------------------------------------------------------------------------
# For local development:
DOMAIN_NAME=default
APP_URL=http://localhost:8000
BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
LOGIN_LINK=http://localhost:3000
SIGN_SCREEN_URL=http://localhost:3000/document-signing/login

# For production (example - replace 'adam' with your domain):
# DOMAIN_NAME=adam
# APP_URL=https://adam.api.sequifi.com
# BASE_URL=https://adam.api.sequifi.com/public/
# FRONTEND_BASE_URL=https://adam.sequifi.com/
# LOGIN_LINK=https://adam.sequifi.com/
# SIGN_SCREEN_URL=https://adam.sequifi.com/document-signing/login

# -----------------------------------------------------------------------------
# PRIMARY DATABASE
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sequifi
DB_USERNAME=root
DB_PASSWORD=
DB_STRICT=false
DB_ENGINE="InnoDB ROW_FORMAT=DYNAMIC"
DB_TRANSACTION_ISOLATION=READ_COMMITTED
DB_PERSISTENT=false
DB_RETRY_ON_FAILURE=true
DB_OPTIONS_TIMEOUT=10

# Read/Write Split (Production with replicas)
# DB_HOST_READ=your-read-replica.rds.amazonaws.com
# DB_HOST_WRITE=your-write-primary.rds.amazonaws.com

# -----------------------------------------------------------------------------
# SCLEARANCE DATABASE (Secondary)
# -----------------------------------------------------------------------------
# DB_HOST_SCLEARANCE=
# DB_DATABASE_SCLEARANCE=sclearance_db
# DB_USERNAME_SCLEARANCE=
# DB_PASSWORD_SCLEARANCE=
# DB_PORT_SCLEARANCE=3306

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=predis              # predis (local) or phpredis (production)
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_PREFIX=sequifi_database_
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=queue
# REDIS_CLUSTER=redis
# REDIS_TIMEOUT=5
# REDIS_READ_TIMEOUT=60
# REDIS_SERIALIZER=php
# REDIS_COMPRESSION=lz4

# -----------------------------------------------------------------------------
# CACHE & SESSION
# -----------------------------------------------------------------------------
# Local: file/sync | Production: redis
CACHE_DRIVER=file
CACHE_PREFIX=sequifi_payroll
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SAME_SITE=lax
# SESSION_SECURE_COOKIE=true     # Enable in production with HTTPS
# SESSION_DOMAIN=.sequifi.com    # For cross-subdomain sessions

# -----------------------------------------------------------------------------
# QUEUE
# -----------------------------------------------------------------------------
# Local: sync | Production: redis
QUEUE_CONNECTION=sync
# AWS_WEBHOOK_QUEUE_CONNECTION=redis
# SQS_PREFIX=https://sqs.us-west-1.amazonaws.com/your-account-id

# -----------------------------------------------------------------------------
# HORIZON (Queue Dashboard)
# -----------------------------------------------------------------------------
HORIZON_NAME=sequifi-local
HORIZON_PREFIX=sequifi_horizon:
HORIZON_PATH=horizon
# HORIZON_BALANCE=auto
# HORIZON_MAX_PROCESSES=6
# HORIZON_MIN_PROCESSES=2
# HORIZON_MEMORY=512
# HORIZON_TIMEOUT=300
# HORIZON_TRIES=3
# HORIZON_SUPERVISOR_COOLDOWN=3
# HORIZON_SUPERVISOR_MAX_SHIFT=1
# HORIZON_SUPERVISOR_SLEEP=3

# -----------------------------------------------------------------------------
# BROADCASTING (Real-time)
# -----------------------------------------------------------------------------
# Local: log | Production: pusher
BROADCAST_DRIVER=log
# BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Node.js Pusher (if using separate Node service)
# PUSHER_APP_ID_NODE=
# PUSHER_APP_KEY_NODE=
# PUSHER_APP_SECRET_NODE=
# PUSHER_APP_CLUSTER_NODE=
# MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
# MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# -----------------------------------------------------------------------------
# API AUTHENTICATION (Sanctum)
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
# Production: your-domain.sequifi.com,*.sequifi.com

# -----------------------------------------------------------------------------
# MAIL
# -----------------------------------------------------------------------------
# Local: log | Production: ses-role or smtp
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@sequifi.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email Testing Mode (EMAIL_TESTING=1 uses dev settings)
EMAIL_TESTING=0
# MAIL_DEV_MAILER=smtp
# MAIL_DEV_HOST=smtp.sendgrid.net
# MAIL_DEV_PORT=587
# MAIL_DEV_USERNAME=
# MAIL_DEV_PASSWORD=
# MAIL_DEV_ENCRYPTION=tls
# MAIL_DEV_FROM_ADDRESS=no-return@sequifi.com
# MAIL_DEV_FROM_NAME=Sequifi

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_LEVEL=debug                  # debug (local) or notice (production)
# LOG_DEPRECATIONS_CHANNEL=null

# -----------------------------------------------------------------------------
# AWS SERVICES
# -----------------------------------------------------------------------------
AWS_DEFAULT_REGION=us-west-1
AWS_USE_IAM_ROLE=false           # true in production (EC2/ECS)
AWS_USE_PATH_STYLE_ENDPOINT=false

# S3 Buckets
AWS_BUCKET=
# AWS_BUCKET_PRIVATE=sequifi-private-files
# AWS_BUCKET_PUBLIC=sequifi
# AWS_DEFAULT_REGION_PRIVATE=us-west-1
# AWS_DEFAULT_REGION_PUBLIC=us-west-1
# AWS_USE_PATH_STYLE_ENDPOINT_PRIVATE=false
# AWS_USE_PATH_STYLE_ENDPOINT_PUBLIC=false

# S3/CloudFront URLs
# AWS_S3BUCKET_URL=https://your-cloudfront-distribution.cloudfront.net
# AWS_S3BUCKET_OLD_URL=https://your-bucket.s3.us-west-1.amazonaws.com
# S3_BUCKET_PUBLIC_URL=

# Encrypted AWS Credentials (for production without IAM roles)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# ENCRYPTED_AWS_ACCESS_KEY_ID_PRIVATE=
# ENCRYPTED_AWS_ACCESS_KEY_ID_PUBLIC=
# ENCRYPTED_AWS_SECRET_ACCESS_KEY_PRIVATE=
# ENCRYPTED_AWS_SECRET_ACCESS_KEY_PUBLIC=

# -----------------------------------------------------------------------------
# CLICKHOUSE (API Metrics)
# -----------------------------------------------------------------------------
# API_METRICS_STORAGE=clickhouse
# CLICKHOUSE_HOST=
# CLICKHOUSE_PORT=8443
# CLICKHOUSE_DATABASE=
# CLICKHOUSE_USERNAME=
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_TIMEOUT=30
# CLICKHOUSE_CONNECT_TIMEOUT=60
# CLICKHOUSE_METRICS_ENABLED=true
# CLICKHOUSE_METRICS_HOST=
# CLICKHOUSE_METRICS_PORT=8443
# CLICKHOUSE_METRICS_DATABASE=Api_metrices
# CLICKHOUSE_METRICS_USERNAME=
# CLICKHOUSE_METRICS_PASSWORD=
# CLICKHOUSE_METRICS_PROTOCOL=https
# CLICKHOUSE_METRICS_TIMEOUT=5.0
# CLICKHOUSE_METRICS_CONNECT_TIMEOUT=10

# -----------------------------------------------------------------------------
# SENTRY (Error Tracking)
# -----------------------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0      # 0-1.0 (1.0 = 100% sampling)
# SENTRY_PROFILES_SAMPLE_RATE=0
# SENTRY_MONITORING_ENABLED=true
# SENTRY_TRACING_ENABLED=true
# SENTRY_DEBUG=false

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
# Generate: openssl rand -base64 32 (key), openssl rand -base64 16 (iv)
ENCRYPTION_KEY=
ENCRYPTION_IV=
ENCRYPTION_CIPHER_ALGO=aes-256-cbc

# -----------------------------------------------------------------------------
# ADMIN USER PASSWORDS (Required for seeding)
# -----------------------------------------------------------------------------
# Used by: php artisan migrate:fresh --seed
# Creates: superadmin@sequifi.com, csteam@sequifi.com, devadmin@sequifi.com
SUPER_ADMIN_PASSWORD="Admin#123"
CS_ADMIN_PASSWORD="CsAdmin#123"
DEV_ADMIN_PASSWORD="DevAdmin#123"

# -----------------------------------------------------------------------------
# SSO (Single Sign-On)
# -----------------------------------------------------------------------------
# SSO_SHARED_SECRET=

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# -----------------------------------------------------------------------------
# Google Services
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_KEY=

# -----------------------------------------------------------------------------
# Facebook
# -----------------------------------------------------------------------------
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# QuickBooks
# -----------------------------------------------------------------------------
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_BASE_URL=Production
# QUICKBOOKS_OAUTH_SCOPE=com.intuit.quickbooks.accounting
# QUICKBOOKS_REDIRECT_URI=
# QUICKBOOKS_API_URL=
# QUICKBOOKS_SANDBOX=false

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_TYPE=test                 # test or live
# STRIPE_KEY_LIVE=
# STRIPE_KEY_TEST=

# -----------------------------------------------------------------------------
# Everee (Payroll)
# -----------------------------------------------------------------------------
# EVEREE_API_KEY=
# EVEREE_TENANT_ID=
# W2_EVEREE_API_KEY=
# W2_EVEREE_TENANT_ID=

# -----------------------------------------------------------------------------
# HighLevel CRM
# -----------------------------------------------------------------------------
# HIGHLEVEL_API_TOKEN=
# HIGHLEVEL_LOCATION_ID=
# HIGHLEVEL_API_VERSION=2021-07-28

# -----------------------------------------------------------------------------
# Jira (Support Tickets)
# -----------------------------------------------------------------------------
# JIRA_API_BASE_URL=https://your-org.atlassian.net/
# JIRA_EMAIL=
# JIRA_SECRET_KEY=

# -----------------------------------------------------------------------------
# ChatGPT / OpenAI
# -----------------------------------------------------------------------------
# CHAT_GPT_TOKEN_KEY=

# -----------------------------------------------------------------------------
# Turn AI
# -----------------------------------------------------------------------------
# TURN_AI_URL=https://api.turn.ai/v1/
# TURN_AI_JWT_TOKEN=

# -----------------------------------------------------------------------------
# SSL.com (Document Signing)
# -----------------------------------------------------------------------------
# SSLDOTCOM_TOKEN_BASE_URL=https://login.ssl.com
# SSLDOTCOM_BASE_URL=https://ds.ssl.com
# SSLDOTCOM_CLIENT_ID=
# SSLDOTCOM_CLIENT_SECRET=
# SSLDOTCOM_USERNAME=
# SSLDOTCOM_PASSWORD=
# SSLDOTCOM_SPRINGBOOT_APP_URL=
# SSLDOTCOM_CREDENTIAL_ID=

# -----------------------------------------------------------------------------
# Sign Server
# -----------------------------------------------------------------------------
# SIGN_SERVER_URL=
# SIGN_SERVER_WORKER=
# SIGN_SERVER_WORKER_USERNAME=
# SIGN_SERVER_WORKER_PASS=
# SIGN_SERVER_STORAGE_DISK=local

# -----------------------------------------------------------------------------
# OneSignal (Push Notifications)
# -----------------------------------------------------------------------------
# ONESIGNAL_API_KEY=

# -----------------------------------------------------------------------------
# MongoDB (SequifiArena)
# -----------------------------------------------------------------------------
# MONGODB_URI=
# MONGODB_DATABASE=SequifiArena

# -----------------------------------------------------------------------------
# Mailgun / Postmark (Alternative mail providers)
# -----------------------------------------------------------------------------
# MAILGUN_DOMAIN=
# MAILGUN_SECRET=
# MAILGUN_ENDPOINT=api.mailgun.net
# POSTMARK_TOKEN=

# =============================================================================
# PERFORMANCE & MONITORING
# =============================================================================

# -----------------------------------------------------------------------------
# Job & Performance Metrics
# -----------------------------------------------------------------------------
# JOB_METRICS_ENABLED=true
# PERFORMANCE_TRACKING_ENABLED=true

# -----------------------------------------------------------------------------
# Payroll Cache & Observer
# -----------------------------------------------------------------------------
# PAYROLL_CACHE_DRIVER=file
# PAYROLL_CACHE_FALLBACK=database
# PAYROLL_CACHE_TTL=3600
# PAYROLL_LOCK_TIMEOUT=10
# PAYROLL_OBSERVER_ENABLED=true
# PAYROLL_OBSERVER_LOG_LEVEL=info
# PAYROLL_OBSERVER_RETRY_ATTEMPTS=3
# PAYROLL_OBSERVER_TRANSACTION_TIMEOUT=30
# PAYROLL_USE_DB_FALLBACK=true

# -----------------------------------------------------------------------------
# New Relic APM
# -----------------------------------------------------------------------------
# NEW_RELIC_ENABLED=false
# NEW_RELIC_LICENSE_KEY=
# NEW_RELIC_APP_NAME="Sequifi Backend"
# NEW_RELIC_HORIZON_APP_NAME="Sequifi Backend - Horizon"
# NEW_RELIC_ENVIRONMENT=local
# NEW_RELIC_USER_KEY=
# NEW_RELIC_ACCOUNT_ID=
# NEW_RELIC_REGION=US
# NEW_RELIC_LOG_LEVEL=info
# NEW_RELIC_ALERT_POLICY_ID=

# =============================================================================
# OCTANE / SWOOLE (Production Server)
# =============================================================================

# -----------------------------------------------------------------------------
# Octane Settings
# -----------------------------------------------------------------------------
# OCTANE_SERVER=swoole
# OCTANE_HTTPS=false
# OCTANE_WATCH=false
# OCTANE_WARM_OCTANE=true
# OCTANE_GC_ENABLED=true
# OCTANE_CACHE_TABLE=1000
# OCTANE_TICK_INTERVAL=1000

# -----------------------------------------------------------------------------
# Swoole Settings
# -----------------------------------------------------------------------------
# SWOOLE_WORKERS=8
# SWOOLE_TASK_WORKERS=4
# SWOOLE_REACTOR_NUM=4
# SWOOLE_MAX_REQUEST=1000
# SWOOLE_MAX_CONN=5000
# SWOOLE_MAX_WAIT_TIME=300
# SWOOLE_LOG_LEVEL=2
# SWOOLE_HTTP_COMPRESSION=true
# SWOOLE_HTTP_COMPRESSION_LEVEL=4
# SWOOLE_BUFFER_OUTPUT_SIZE=16384
# SWOOLE_SOCKET_BUFFER_SIZE=4194304
# SWOOLE_PACKAGE_MAX_LENGTH=4194304

# =============================================================================
# MISC
# =============================================================================
PAGINATE=10
# MEMCACHED_HOST=127.0.0.1
# RECALCULATE_TIERED_SALES=0
# EXPECTED_QUEUES=
# MINIMUM_WORKERS=1
# STUCK_JOB_THRESHOLD_HOURS=4
