{
    "name": "keenthemes/metronic-laravel",
    "type": "project",
    "description": "The Metronic in the Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "anlutro/l4-settings": "^1.3",
        "aws/aws-sdk-php": "^3.343",
        "barryvdh/laravel-dompdf": "^2.0",
        "barryvdh/laravel-ide-helper": "^2.13",
        "cybercog/laravel-clickhouse": "^0.1.0",
        "darkaonline/l5-swagger": "*",
        "dragonmantank/cron-expression": "^3.4",
        "firebase/php-jwt": "^6.11",
        "google/cloud-bigquery": "^1.32",
        "guzzlehttp/guzzle": "^7.2",
        "jackiedo/log-reader": "^2.3",
        "laravel/boost": "^1.6",
        "laravel/framework": "^10.48",
        "laravel/horizon": "^5.39",
        "laravel/octane": "^2.3",
        "laravel/pennant": "^1.18",
        "laravel/sanctum": "^3.3",
        "laravel/slack-notification-channel": "^3.5",
        "laravel/socialite": "^5.6",
        "laravel/tinker": "^2.8",
        "league/flysystem-aws-s3-v3": "*",
        "livewire/livewire": "^2.12",
        "maatwebsite/excel": "^3.1",
        "mongodb/laravel-mongodb": "^4.0",
        "opcodesio/log-viewer": "^3.1",
        "phpseclib/phpseclib": "^3.0",
        "predis/predis": "^3.3",
        "psr/simple-cache": "2.0",
        "pusher/pusher-php-server": "^7.2",
        "quickbooks/v3-php-sdk": "^6.2",
        "sentry/sentry-laravel": "^4.13",
        "spatie/laravel-activitylog": "^4.7",
        "spatie/laravel-permission": "^5.8",
        "symfony/process": "^6.4",
        "yajra/laravel-datatables-buttons": "^9.0.10",
        "yajra/laravel-datatables-html": "9.4.0",
        "yajra/laravel-datatables-oracle": "^10.3"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/breeze": "^1.18",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.1",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        },
        "platform": {
            "php": "8.1.2"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/boost"
            ]
        }
    },
    "autoload": {
        "files": [
            "app/helpers.php",
            "app/CustomHelper.php",
            "app/SequiDocsHelper.php",
            "app/PayrollHelper.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate"
        ],
        "dev-post-update-cmd": [
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:meta"
        ]
    },
    "repositories": []
}
